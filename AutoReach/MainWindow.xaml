<Window x:Class="AutoReach.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoReach Professional" Height="700" Width="850" Background="#1E1E1E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Configuration" Foreground="White" BorderBrush="#333" Margin="0,0,0,15" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Your Email:" Foreground="Gray" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="TxtEmail" Grid.Column="1" Margin="5" Padding="3"/>

                <TextBlock Text="App Password:" Grid.Row="1" Foreground="Gray" VerticalAlignment="Center" Margin="5"/>
                <PasswordBox x:Name="TxtPassword" Grid.Row="1" Grid.Column="1" Margin="5" Padding="3"/>

                <TextBlock Text="Subject:" Grid.Row="2" Foreground="Gray" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="TxtSubject" Grid.Row="2" Grid.Column="1" Margin="5" Padding="3"/>

                <TextBlock Text="Email Body:" Grid.Row="3" Foreground="Gray" VerticalAlignment="Top" Margin="5,10,5,5"/>
                <TextBox x:Name="TxtBody" Grid.Row="3" Grid.Column="1" Margin="5" Padding="3" 
                         Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Text="Resume Path:" Grid.Row="4" Foreground="Gray" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="TxtResumePath" Grid.Row="4" Grid.Column="1" Margin="5" Padding="3" IsReadOnly="True"/>
                <Button Content="Browse" Grid.Row="4" Grid.Column="2" Margin="5" Width="60" Click="BrowseResume_Click"/>

                <TextBlock Text="Email List:" Grid.Row="5" Foreground="Gray" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="TxtListPath" Grid.Row="5" Grid.Column="1" Margin="5" Padding="3" IsReadOnly="True"/>
                <Button Content="Browse" Grid.Row="5" Grid.Column="2" Margin="5" Width="60" Click="BrowseList_Click"/>
            </Grid>
        </GroupBox>

        <TextBox Grid.Row="1" x:Name="LogTerminal" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                 Background="Black" Foreground="Lime" FontFamily="Consolas" Padding="10"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="BtnStart" Content="START BATCH" Width="120" Height="35" Click="BtnStart_Click" Background="#007ACC" Foreground="White"/>
            <Button x:Name="BtnStop" Content="STOP" Width="80" Height="35" Margin="10,0,0,0" Click="BtnStop_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>