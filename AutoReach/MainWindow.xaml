<Window x:Class="AutoReach.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoReach Professional" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen" Background="#F4F7FE" FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR ═══════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#111827">
            <StackPanel Margin="15">
                <TextBlock Text="AutoReach Professional" Foreground="White"
                           FontSize="16" FontWeight="Bold" Margin="0,10,0,20"/>

                <Button Content="+ New Template" Background="#8B5CF6" Foreground="White"
                        Height="35" BorderThickness="0" Margin="0,0,0,20" Cursor="Hand"
                        Click="ComingSoon_Click">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                    </Button.Resources>
                </Button>

                <Button Content="Standard Follow-up" Foreground="#9CA3AF" Background="Transparent"
                        BorderThickness="0" HorizontalAlignment="Left"
                        Margin="5,10,0,10" Cursor="Hand" Click="ComingSoon_Click"/>

                <Border Background="#1F2937" CornerRadius="4" Padding="10">
                    <TextBlock Text="Job Application v1" Foreground="White"/>
                </Border>

                <Button Content="Recruiter Outreach" Foreground="#9CA3AF" Background="Transparent"
                        BorderThickness="0" HorizontalAlignment="Left"
                        Margin="5,10,0,10" Cursor="Hand" Click="ComingSoon_Click"/>
            </StackPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ═══════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <TextBlock Text="Desktop Dashboard" FontWeight="SemiBold" FontSize="18" VerticalAlignment="Center"/>
                    <Ellipse Width="35" Height="35" Fill="#D1D5DB" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Content area -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <!-- ── LEFT: Template Editor ─────────────────────────────── -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="Template Editor" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"/>
                        <Button Content="+ Edit template" HorizontalAlignment="Right"
                                Padding="10,5" Background="White" BorderBrush="#E5E7EB"/>
                    </Grid>

                    <Border Style="{StaticResource CardStyle}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Job Application v1" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                            <!-- Subject -->
                            <TextBlock Text="Subject line" Foreground="#4B5563" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtSubject" Height="35" Padding="5,0"
                                     Margin="0,0,0,15" BorderBrush="#D1D5DB"
                                     Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- Body -->
                            <TextBlock Text="Email body" Foreground="#4B5563" Margin="0,0,0,5"/>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1,1,1,0"
                                    Background="#F9FAFB" Padding="10,5" CornerRadius="4,4,0,0">
                                <TextBlock Text="B  I  U  S  ... " Foreground="#6B7280" FontWeight="Bold"/>
                            </Border>
                            <TextBox x:Name="TxtBody" Height="150" TextWrapping="Wrap"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     BorderBrush="#D1D5DB" Padding="10" BorderThickness="1,0,1,1"
                                     Text="{Binding TemplateBody, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- Resume drop zone -->
                            <Border Style="{StaticResource DropZoneStyle}" Height="60"
                                    Margin="0,20,0,10" AllowDrop="True" Drop="Resume_Drop">
                                <Border.BorderBrush>
                                    <VisualBrush>
                                        <VisualBrush.Visual>
                                            <Rectangle StrokeDashArray="4 2" Stroke="#9CA3AF"
                                                       StrokeThickness="1" Width="800" Height="60"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Border.BorderBrush>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ResumePathDisplay}"
                                               Foreground="#6B7280" HorizontalAlignment="Left"
                                               VerticalAlignment="Center" Margin="20,0,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="1" Content="Browse"
                                            Click="BrowseResume_Click"
                                            Margin="0,0,15,0" Padding="15,5" Height="30"
                                            Background="#E5E7EB" BorderThickness="0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Email list drop zone -->
                            <Border Style="{StaticResource DropZoneStyle}" Height="60"
                                    AllowDrop="True" Drop="EmailList_Drop">
                                <Border.BorderBrush>
                                    <VisualBrush>
                                        <VisualBrush.Visual>
                                            <Rectangle StrokeDashArray="4 2" Stroke="#9CA3AF"
                                                       StrokeThickness="1" Width="800" Height="60"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Border.BorderBrush>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding EmailListPathDisplay}"
                                               Foreground="#6B7280" HorizontalAlignment="Left"
                                               VerticalAlignment="Center" Margin="20,0,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="1" Content="Browse"
                                            Click="BrowseList_Click"
                                            Margin="0,0,15,0" Padding="15,5" Height="30"
                                            Background="#E5E7EB" BorderThickness="0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── RIGHT: Configuration & Activity ───────────────────── -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Configuration &amp; Preview"
                               FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10"/>

                    <!-- Email settings card -->
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="Email Settings" FontWeight="Bold" Margin="0,0,0,15"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="Sender Name" Foreground="#4B5563" Margin="0,0,0,5"/>
                                    <TextBox x:Name="TxtSenderName" Height="35" Padding="5,0"
                                             BorderBrush="#D1D5DB" Margin="0,0,0,10"
                                             Text="{Binding SenderName, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Your Email" Foreground="#4B5563" Margin="0,0,0,5"/>
                                    <TextBox x:Name="TxtEmail" Height="35" Padding="5,0"
                                             BorderBrush="#D1D5DB"
                                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="App Password" Foreground="#4B5563" Margin="0,0,0,5"/>
                                    <PasswordBox x:Name="TxtPassword" Height="35" Padding="5,0"
                                                 BorderBrush="#D1D5DB" Margin="0,0,0,10"
                                                 PasswordChanged="TxtPassword_PasswordChanged"/>

                                    <TextBlock Text="Daily Limit" Foreground="#4B5563" Margin="0,0,0,5"/>
                                    <TextBox x:Name="TxtDailyLimit" Height="35" Padding="5,0"
                                             BorderBrush="#D1D5DB"
                                             Text="{Binding DailyLimit, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Recent Activity card -->
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,220,0,0">
                        <StackPanel>
                            <TextBlock Text="Recent Activity" FontWeight="Bold" Margin="0,0,0,15"/>
                            <DataGrid x:Name="ActivityGrid"
                                      ItemsSource="{Binding ActivityLogs}"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#E5E7EB"
                                      BorderThickness="0"
                                      Background="White"
                                      RowBackground="White"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Recipient" Binding="{Binding Recipient}" Width="*"/>
                                    <DataGridTextColumn Header="Status"    Binding="{Binding Status}"    Width="80"/>
                                    <DataGridTextColumn Header="Time Sent" Binding="{Binding TimeSent}"  Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Action buttons -->
                    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BtnStart" Grid.Column="0"
                                    Content="Start Batch" Height="40"
                                    Background="#2563EB" Foreground="White"
                                    Margin="0,0,5,0"
                                    Command="{Binding StartCommand}">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                </Button.Resources>
                            </Button>

                            <Button x:Name="BtnStop" Grid.Column="1"
                                    Content="Stop" Height="40"
                                    Background="#F3F4F6" Foreground="#374151"
                                    Margin="5,0,0,0"
                                    Command="{Binding StopCommand}">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
